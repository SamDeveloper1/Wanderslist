<!-- Itinerary Modal -->
<div class="modal fade" id="itineraryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content" style="border-radius:1rem; overflow:hidden;">
      <div class="modal-header" style="background-color:#fe424d;">
        <h5 class="modal-title text-white">
          <i class="fa-solid fa-map me-2"></i>Plan My Trip to <%=listing.location%>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">

        <!-- Days selector -->
        <div id="itinerary-form" class="p-4">
          <p class="text-muted mb-3">How many days are you planning to stay?</p>
          <div class="d-flex align-items-center gap-3 mb-4">
            <button class="btn btn-outline-secondary rounded-circle" id="decrease-days" type="button" style="width:38px;height:38px;">
              <i class="fa-solid fa-minus" style="font-size:0.75rem;"></i>
            </button>
            <div class="text-center">
              <h2 class="mb-0 fw-bold" id="days-display">3</h2>
              <small class="text-muted">days</small>
            </div>
            <button class="btn btn-outline-secondary rounded-circle" id="increase-days" type="button" style="width:38px;height:38px;">
              <i class="fa-solid fa-plus" style="font-size:0.75rem;"></i>
            </button>
          </div>
          <button class="btn btn-danger w-100 py-2" id="generate-btn">
            <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate My Itinerary
          </button>
        </div>

        <!-- Loading -->
        <div id="itinerary-loading" style="display:none;" class="text-center py-5">
          <div class="spinner-border text-danger mb-3" role="status"></div>
          <p class="text-muted fw-bold">Crafting your perfect trip...</p>
          <small class="text-muted">This may take a few seconds</small>
        </div>

        <!-- Result -->
        <div id="itinerary-result" style="display:none;"></div>

      </div>
    </div>
  </div>
</div>

<script>
  let tripDays = 3;
  const daysDisplay = document.getElementById("days-display");
  const decreaseDays = document.getElementById("decrease-days");
  const increaseDays = document.getElementById("increase-days");
  const generateBtn = document.getElementById("generate-btn");
  const itineraryLoading = document.getElementById("itinerary-loading");
  const itineraryResult = document.getElementById("itinerary-result");
  const itineraryForm = document.getElementById("itinerary-form");

  if(decreaseDays) {
    decreaseDays.addEventListener("click", () => {
      if(tripDays > 1) { tripDays--; daysDisplay.textContent = tripDays; }
    });
  }

  if(increaseDays) {
    increaseDays.addEventListener("click", () => {
      if(tripDays < 10) { tripDays++; daysDisplay.textContent = tripDays; }
    });
  }

  if(generateBtn) {
    generateBtn.addEventListener("click", async () => {
      itineraryForm.style.display = "none";
      itineraryLoading.style.display = "block";
      itineraryResult.style.display = "none";

      try {
        const res = await fetch(`/listings/${listing._id}/itinerary/generate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            days: tripDays,
            location: listing.location,
            country: listing.country,
          }),
        });

        const data = await res.json();
        itineraryLoading.style.display = "none";

        if (!data.success) {
          itineraryForm.style.display = "block";
          alert("Something went wrong. Please try again.");
          return;
        }

        const itin = data.itinerary;

        let html = `
          <div style="background:#fe424d; padding: 1.5rem 2rem;">
            <h4 class="text-white fw-bold mb-0">
              <i class="fa-solid fa-location-dot me-2"></i>${itin.location}
            </h4>
            <small class="text-white opacity-75">${tripDays}-Day Travel Guide</small>
          </div>
        `;

        itin.days.forEach((day, index) => {
          const bgColor = index % 2 === 0 ? "#fff" : "#fafafa";
          html += `
            <div style="background:${bgColor}; border-bottom: 1px solid #f0f0f0;">

              <!-- Day Header -->
              <div style="padding: 1.2rem 2rem 0.5rem; border-left: 5px solid #fe424d;">
                <div class="d-flex align-items-center gap-2">
                  <span style="background:#fe424d; color:white; font-size:0.75rem; font-weight:700; padding:0.2rem 0.6rem; border-radius:1rem;">DAY ${day.day}</span>
                  <h5 class="mb-0 fw-bold" style="color:#222;">${day.title}</h5>
                </div>
              </div>

              <!-- Time Sections -->
              <div style="padding: 0.5rem 2rem 1rem;">
                <div class="d-flex gap-3 mb-3 mt-3">
                  <div style="min-width:80px; text-align:center;">
                    <div style="font-size:1.4rem;">🌅</div>
                    <small style="font-size:0.7rem; color:#fe424d; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;">Morning</small>
                  </div>
                  <p style="font-size:0.9rem; color:#444; line-height:1.6; margin:0; padding-top:0.2rem;">${day.morning}</p>
                </div>

                <div class="d-flex gap-3 mb-3">
                  <div style="min-width:80px; text-align:center;">
                    <div style="font-size:1.4rem;">☀️</div>
                    <small style="font-size:0.7rem; color:#fe424d; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;">Afternoon</small>
                  </div>
                  <p style="font-size:0.9rem; color:#444; line-height:1.6; margin:0; padding-top:0.2rem;">${day.afternoon}</p>
                </div>

                <div class="d-flex gap-3 mb-3">
                  <div style="min-width:80px; text-align:center;">
                    <div style="font-size:1.4rem;">🌙</div>
                    <small style="font-size:0.7rem; color:#fe424d; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;">Evening</small>
                  </div>
                  <p style="font-size:0.9rem; color:#444; line-height:1.6; margin:0; padding-top:0.2rem;">${day.evening}</p>
                </div>

                <!-- Food + Tip -->
                <div style="background:#fff8f8; border-radius:0.75rem; padding:0.85rem 1rem; margin-top:0.5rem;">
                  <div class="d-flex gap-2 mb-2">
                    <span style="font-size:1rem;">🍽️</span>
                    <p style="font-size:0.85rem; margin:0; color:#555;"><b style="color:#222;">Must Try:</b> ${day.food}</p>
                  </div>
                  <div class="d-flex gap-2">
                    <span style="font-size:1rem;">💡</span>
                    <p style="font-size:0.85rem; margin:0; color:#555;"><b style="color:#222;">Pro Tip:</b> ${day.tip}</p>
                  </div>
                </div>
              </div>
            </div>
          `;
        });

        html += `
          <div class="p-3">
            <button class="btn btn-outline-danger w-100" id="regenerate-btn">
              <i class="fa-solid fa-rotate me-2"></i>Plan Again
            </button>
          </div>
        `;

        itineraryResult.innerHTML = html;
        itineraryResult.style.display = "block";

        document.getElementById("regenerate-btn").addEventListener("click", () => {
          itineraryResult.style.display = "none";
          itineraryForm.style.display = "block";
        });

      } catch (err) {
        itineraryLoading.style.display = "none";
        itineraryForm.style.display = "block";
        alert("Something went wrong. Please try again.");
      }
    });
  }
</script>