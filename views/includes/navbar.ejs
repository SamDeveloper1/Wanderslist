<style>
  .btn-search {
    color: #fff;
    background-color: #fe424d;
    border: none;
    padding: 0.4rem 1rem;
    border-radius: 0 25px 25px 0;
    white-space: nowrap;
  }
  .btn-search:hover { background-color: #e0333d; color: #fff; }
  .search-inp {
    border-radius: 25px 0 0 25px;
    padding: 0.4rem 1rem;
    border-right: none;
  }
  .search-form {
    width: 100%;
  }
  @media (min-width: 768px) {
    .search-form { width: auto; }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <form class="d-flex search-form my-2 my-md-0 mx-md-3" role="search" action="/listings" method="GET">
        <input class="form-control search-inp" type="search" name="search" placeholder="Search Destinations" value=""/>
        <button class="btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <div class="navbar-nav">
        <a class="nav-link" href="/listings/new">List Your Place</a>
        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>SignUp</b></a>
          <a class="nav-link" href="/login"><b>LogIn</b></a>
        <% } %>
        <% if(currUser) { %>
          <a class="nav-link" href="/logout"><b>Log Out</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>