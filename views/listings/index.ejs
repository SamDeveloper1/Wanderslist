<% layout("/layouts/boilerplate") %>
<style>
  #filters {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    gap: 0.5rem;
  }
  #filters::-webkit-scrollbar { display: none; }

  .filter {
    text-align: center;
    margin-top: 1.5rem;
    min-width: 60px;
    opacity: 0.7;
    flex-shrink: 0;
  }
   .filter-link {
  text-decoration: none;
  color: #222;
  }
   .active-filter {
  opacity: 1;
  border-bottom: 2px solid #222;
  }
  .filter:hover { opacity: 1; cursor: pointer; }
  .filter p { font-size: 0.75rem; margin: 0.25rem 0 0; }

  .tax-toggle {
    border: 1px solid rgba(111,108,108,0.5);
    border-radius: 1rem;
    margin-top: 1.5rem;
    height: 3rem;
    display: flex;
    padding: 0 1rem;
    align-items: center;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .tax-info { display: none; }
</style>

<div id="filters">
  <div class="filter <%= !currCategory ? 'active-filter' : '' %>">
  <a href="/listings" class="filter-link">
    <div><i class="fa-solid fa-list"></i></div><p>All</p>
  </a>
  </div>
 <div class="filter <%= currCategory === 'trending' ? 'active-filter' : '' %>">
  <a href="/listings?category=trending" class="filter-link">
    <div><i class="fa-solid fa-fire"></i></div><p>Trending</p>
  </a>
</div>
<div class="filter <%= currCategory === 'rooms' ? 'active-filter' : '' %>">
  <a href="/listings?category=rooms" class="filter-link">
    <div><i class="fa-solid fa-bed"></i></div><p>Rooms</p>
  </a>
</div>
<div class="filter <%= currCategory === 'iconic-cities' ? 'active-filter' : '' %>">
  <a href="/listings?category=iconic-cities" class="filter-link">
    <div><i class="fa-solid fa-mountain-city"></i></div><p>Iconic Cities</p>
  </a>
</div>
<div class="filter <%= currCategory === 'mountains' ? 'active-filter' : '' %>">
  <a href="/listings?category=mountains" class="filter-link">
    <div><i class="fa-solid fa-mountain"></i></div><p>Mountains</p>
  </a>
</div>
<div class="filter <%= currCategory === 'castles' ? 'active-filter' : '' %>">
  <a href="/listings?category=castles" class="filter-link">
    <div><i class="fa-brands fa-fort-awesome"></i></div><p>Castles</p>
  </a>
</div>
<div class="filter <%= currCategory === 'amazing-pools' ? 'active-filter' : '' %>">
  <a href="/listings?category=amazing-pools" class="filter-link">
    <div><i class="fa-solid fa-person-swimming"></i></div><p>Amazing Pools</p>
  </a>
</div>
<div class="filter <%= currCategory === 'camping' ? 'active-filter' : '' %>">
  <a href="/listings?category=camping" class="filter-link">
    <div><i class="fa-solid fa-campground"></i></div><p>Camping</p>
  </a>
</div>
<div class="filter <%= currCategory === 'farms' ? 'active-filter' : '' %>">
  <a href="/listings?category=farms" class="filter-link">
    <div><i class="fa-solid fa-cow"></i></div><p>Farms</p>
  </a>
</div>
<div class="filter <%= currCategory === 'arctic' ? 'active-filter' : '' %>">
  <a href="/listings?category=arctic" class="filter-link">
    <div><i class="fa-solid fa-snowflake"></i></div><p>Arctic</p>
  </a>
</div>
<div class="filter <%= currCategory === 'boats' ? 'active-filter' : '' %>">
  <a href="/listings?category=boats" class="filter-link">
    <div><i class="fa-solid fa-ship"></i></div><p>Boats</p>
  </a>
</div>
<div class="filter <%= currCategory === 'domes' ? 'active-filter' : '' %>">
  <a href="/listings?category=domes" class="filter-link">
    <div><i class="fa-solid fa-landmark-dome"></i></div><p>Domes</p>
  </a>
</div>
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault" />
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<br />
<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 mt-3 justify-content-center">
    <% if(allListings.length === 0) { %>
  <div class="col-12 text-center mt-5 w-100">
    <i class="fa-solid fa-magnifying-glass" style="font-size:3rem; color:#ddd;"></i>
    <h4 class="mt-3 text-muted">No listings found</h4>
    <p class="text-muted">Try searching for a different location</p>
    <a href="/listings" class="btn btn-outline-danger mt-2">Clear Search</a>
  </div>
<% } else { %>
  

  <% for(let listing of allListings) { %>
  <div class="col mb-4">
    <a href="/listings/<%= listing._id %>" class="listing-links">
      <div class="card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" />
        <div class="card-body">
          <div class="card-img-overlay"></div>
          <p class="card-text">
            <b><%= listing.title %></b><br />
            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  </div>
  <% } %>
<% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      info.style.display = info.style.display !== "inline" ? "inline" : "none";
    }
  });
</script>