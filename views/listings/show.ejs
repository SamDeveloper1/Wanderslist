<% layout("/layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="row mt-3">

  <div class="col-12 col-md-8 offset-md-2 mb-2">
    <h3><%=listing.title%></h3>
  </div>

  <div class="card col-12 col-md-8 offset-md-2 show-card listing-card mb-4">
    <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image" />
    <div class="card-body px-3 py-3">

  <!-- Host + Category in same row -->
  <div class="d-flex justify-content-between align-items-center mb-2">
    <div class="d-flex align-items-center gap-2">
      <div style="background:#fe424d; color:white; border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <i class="fa-solid fa-user" style="font-size:0.75rem;"></i>
      </div>
      <span class="text-muted" style="font-size:0.85rem;">Hosted by <b style="color:#222;"><%=listing.owner.username%></b></span>
    </div>
    <span class="badge rounded-pill px-3 py-1" style="background:#fff0f0; color:#fe424d; border:1px solid #fe424d; font-size:0.78rem; text-transform:capitalize;">
      <%=listing.category%>
    </span>
  </div>

  <!-- Description -->
  <p class="text-muted mb-2" style="font-size:0.9rem; line-height:1.5;"><%=listing.description%></p>

  <!-- Price + Location -->
  <div class="mb-1">
    <span style="font-size:1.4rem; font-weight:700; color:#222;">&#8377; <%=listing.price.toLocaleString("en-IN")%></span>
    <span class="text-muted" style="font-size:0.85rem;"> / night</span>
  </div>
  <p class="mb-0" style="font-size:0.88rem; color:#555;">
    <i class="fa-solid fa-location-dot me-1" style="color:#fe424d;"></i><%=listing.location%>, <%=listing.country%>
  </p>

  <% if(currUser && !currUser._id.equals(listing.owner._id)) { %>
  <button class="btn btn-danger w-100 mt-3" data-bs-toggle="modal" data-bs-target="#bookingModal">
    <i class="fa-solid fa-calendar-check me-2"></i>Book Now
  </button>
  <% } %>

  <% if(!currUser) { %>
  <a href="/login" class="btn btn-outline-danger w-100 mt-3">
    <i class="fa-solid fa-right-to-bracket me-2"></i>Login to Book
  </a>
  <% } %>
  <button class="btn btn-outline-danger w-100 mt-2" data-bs-toggle="modal" data-bs-target="#itineraryModal">
  <i class="fa-solid fa-map me-2"></i>Plan My Trip
</button>

</div>
  </div>

  <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
  <div class="col-12 col-md-8 offset-md-2 btns mb-4">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark edit-btn">Edit</a>
    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="btn btn-dark">Delete</button>
    </form>
  </div>
  <% } %>

  <div class="col-12 col-md-8 offset-md-2 mb-3">
    <% if(currUser) { %>
      <hr />
      <h4>Leave a Review</h4>
      <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mt-3 mb-3">
          <label class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>
        <div class="mt-3 mb-3">
          <label class="form-label">Comments</label>
          <textarea name="review[comment]" rows="5" class="form-control" required></textarea>
          <div class="invalid-feedback">Please add some comments</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
        <hr />
      </form>
    <% } %>

    <% if(listing.reviews.length > 0) { %>
      <p><b>All Reviews</b></p>
      <div class="row">
        <% for(let review of listing.reviews) { %>
        <div class="col-12 col-md-6 mb-3">
          <div class="card review-card h-100">
            <div class="card-body">
              <h5 class="card-title">@<%=review.author.username%></h5>
              <p class="starability-result card-text" data-rating="<%=review.rating%>"></p>
              <p class="card-text"><%=review.comment%></p>
              <% if(currUser && currUser._id.equals(review.author._id)) { %>
              <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <div class="col-12 col-md-8 offset-md-2 mb-5">
    <h4>Where you'll be</h4>
    <div id="map"></div>
  </div>

</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius: 1rem; overflow: hidden;">

      <div class="modal-header" style="background-color: #fe424d;">
        <h5 class="modal-title text-white" id="bookingModalLabel">
          <i class="fa-solid fa-calendar-check me-2"></i>Book Your Stay
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-4">
        <div class="mb-3">
          <p class="text-muted mb-1">Property</p>
          <h6 class="fw-bold"><%=listing.title%></h6>
        </div>
        <div class="mb-3">
          <p class="text-muted mb-1">Location</p>
          <h6><%=listing.location%>, <%=listing.country%></h6>
        </div>
        <hr/>
        <div class="mb-3">
          <label class="form-label fw-bold">Number of Nights</label>
          <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline-secondary" id="decrease-btn" type="button">
              <i class="fa-solid fa-minus"></i>
            </button>
            <h5 class="mb-0" id="nights-display">1</h5>
            <button class="btn btn-outline-secondary" id="increase-btn" type="button">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>
        </div>
        <hr/>
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="text-muted">Price per night</span>
          <span>&#8377; <%=listing.price.toLocaleString("en-IN")%></span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="text-muted">Nights</span>
          <span id="nights-count">1</span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="text-muted">GST (18%)</span>
          <span id="gst-amount">&#8377; <%=Math.round(listing.price * 0.18).toLocaleString("en-IN")%></span>
        </div>
        <hr/>
        <div class="d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">Total</h5>
          <h5 class="fw-bold mb-0 text-danger" id="total-amount">
            &#8377; <%=Math.round(listing.price * 1.18).toLocaleString("en-IN")%>
          </h5>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger px-4" id="pay-btn">
          <i class="fa-solid fa-lock me-2"></i>Pay Securely
        </button>
      </div>

    </div>
  </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<%- include("../includes/itinerary-modal.ejs") %>
<script src="/js/map.js"></script>
<script>
  const pricePerNight = <%= listing.price %>;
  const listingId = "<%= listing._id %>";
  const userName = "<%= currUser ? currUser.username : '' %>";

  let nights = 1;

  const nightsDisplay = document.getElementById("nights-display");
  const nightsCount = document.getElementById("nights-count");
  const totalAmountEl = document.getElementById("total-amount");
  const gstAmountEl = document.getElementById("gst-amount");
  const decreaseBtn = document.getElementById("decrease-btn");
  const increaseBtn = document.getElementById("increase-btn");
  const payBtn = document.getElementById("pay-btn");

  function updatePricing() {
    const baseAmount = nights * pricePerNight;
    const gst = Math.round(baseAmount * 0.18);
    const total = baseAmount + gst;
    nightsDisplay.textContent = nights;
    nightsCount.textContent = nights;
    gstAmountEl.innerHTML = "&#8377; " + gst.toLocaleString("en-IN");
    totalAmountEl.innerHTML = "&#8377; " + total.toLocaleString("en-IN");
  }

  if(decreaseBtn) {
    decreaseBtn.addEventListener("click", () => {
      if(nights > 1) { nights--; updatePricing(); }
    });
  }

  if(increaseBtn) {
    increaseBtn.addEventListener("click", () => {
      if(nights < 30) { nights++; updatePricing(); }
    });
  }

  if(payBtn) {
    payBtn.addEventListener("click", async () => {
      const baseAmount = nights * pricePerNight;
      const gst = Math.round(baseAmount * 0.18);
      const totalAmount = baseAmount + gst;

      const res = await fetch(`/listings/${listingId}/booking/create-order`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ nights, amount: totalAmount }),
      });

      const data = await res.json();
      if (!data.success) {
        alert("Something went wrong. Please try again.");
        return;
      }

      const options = {
        key: data.key,
        amount: data.order.amount,
        currency: "INR",
        name: "WandersList",
        description: `${nights} night(s) at ${listing.title}`,
        order_id: data.order.id,
        handler: async function (response) {
          await fetch(`/listings/${listingId}/booking/payment-success`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ ...response, nights, amount: totalAmount }),
          });
          window.location.href = `/listings/${listingId}`;
        },
        prefill: { name: userName },
        theme: { color: "#fe424d" },
      };

      const rzp = new Razorpay(options);
      rzp.open();
    });
  }
</script>